PORT=5000
NODE_ENV=development
SERVICE_NAME=sk-crawlpulse-api
ARTIFACTS_DIR=artifacts
ARTIFACTS_PUBLIC_ROUTE=/artifacts
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true
JSON_BODY_LIMIT=2mb
API_ANALYSIS_ROUTE=/api/analysis
MONGO_URI=mongodb://localhost:27017/sk-crawlpulse
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=1
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=45000
PLAYWRIGHT_HEADLESS=true
CRAWLER_TIMEOUT_MS=30000
CRAWLER_MAX_PAGES=20
CRAWLER_MAX_LINKS_PER_PAGE=40
CRAWLER_MAX_DEPTH=2
CRAWLER_MAX_INTERACTIONS_PER_PAGE=8
BROWSER_EXECUTABLE_PATH=
BROWSER_FALLBACK_EXECUTABLE_PATHS=C:\Program Files\Google\Chrome\Application\chrome.exe|C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
CRAWLER_LOAD_STATE_TIMEOUT_MS=10000
CRAWLER_NETWORK_IDLE_TIMEOUT_MS=5000
CRAWLER_SETTLE_DELAY_MS=750
CRAWLER_NAVIGATION_RECOVERY_SETTLE_TIMEOUT_MS=12000
CRAWLER_EXTENDED_GOTO_TIMEOUT_MS=45000
CRAWLER_RECOVERY_BLANK_TIMEOUT_MS=8000
CRAWLER_RECOVERY_WAIT_MS=1000
CRAWLER_AUTH_SESSION_DETECTION_TIMEOUT_MS=15000
LOGIN_CHECKPOINT_TIMEOUT_SECONDS=180
ARTIFACT_RETENTION_DAYS=7
ARTIFACT_CLEANUP_INTERVAL_MS=3600000
ARTIFACT_CLEANUP_ENABLED=true
ANALYSIS_MAX_CONCURRENT_RUNS=2
ANALYSIS_PROGRESS_FLUSH_INTERVAL_MS=1000
ANALYSIS_LOG_FLUSH_INTERVAL_MS=1500
ANALYSIS_LOG_BATCH_SIZE=50
ANALYSIS_INTERACTION_BATCH_SIZE=25
ANALYSIS_LEASE_HEARTBEAT_INTERVAL_MS=5000
ANALYSIS_QUEUE_POLL_INTERVAL_MS=2000
ANALYSIS_STREAM_HEARTBEAT_INTERVAL_MS=15000

# Email delivery
RESEND_API_KEY=
RESEND_API_ENDPOINT=https://api.resend.com/emails
RESEND_FROM_EMAIL=SK CrawlPulse <onboarding@resend.dev>
RESEND_REPLY_TO_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
OTP_TTL_MINUTES=10
OTP_RESEND_SECONDS=60

# Notifications
SLACK_WEBHOOK_URL=

